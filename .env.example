# PostgreSQL database URLs
# Use `postgres` as the host when running inside Docker Compose.
DATABASE_URL=postgresql+asyncpg://atlas:atlas@postgres:5432/atlasml
DATABASE_SYNC_URL=postgresql+psycopg2://atlas:atlas@postgres:5432/atlasml

# Redis URL
# Use `redis` as the host when running inside Docker Compose.
REDIS_URL=redis://redis:6379

# Logging
LOG_LEVEL=INFO

# Model/runtime settings
DEFAULT_MODEL_TIMEOUT_MS=5000

# Optional: required only when using OpenAI-compatible LLM adapters
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=